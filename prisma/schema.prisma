generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Enrollment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  courseId    String   @db.ObjectId
  enrolledAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model UserQuiz {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  quizId     String   @db.ObjectId
  score      Int      @default(0)
  passed     Boolean  @default(false)
  attemptedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
  @@map("user_quizzes")
}

model UserCourse {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  courseId  String   @db.ObjectId
  progress  Float    @default(0)
  startedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@map("user_courses")
}

model User {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  email          String       @unique
  name           String       @db.String
  password       String
  isVerified     Boolean      @default(false)
  role           UserRole     @default(STUDENT)
  balance        Float        @default(0)
  specialty      String?      @db.String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  profilePicture String?
  accounts       Account[]
  sessions       Session[]
  enrollments    Enrollment[]
  userQuizzes    UserQuiz[]
  userCourses    UserCourse[]
  notes          Note[]

  @@index([role])
  @@map("users")
}

model Course {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  title         String          @db.String
  description   String          @db.String
  price         Float
  thumbnail     String?
  published     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  rating        Float           @default(0)
  totalStudents Int             @default(0)
  sequences     CourseSequence[]
  enrollments   Enrollment[]
  userCourses   UserCourse[]
  exam          Exam?

  @@index([published])
  @@index([price])
  @@map("courses")
}

model CourseSequence {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  title    String  @db.String
  order    Int
  courseId String  @db.ObjectId
  course   Course  @relation(fields: [courseId], references: [id])
  quiz     Quiz?
  video    Video?
  file     File?

  @@index([courseId])
  @@index([order])
  @@map("course_sequences")
}

model Quiz {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  title      String        @db.String
  sequenceId String        @unique @db.ObjectId
  duration   Int?
  attempts   Int           @default(1)
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])
  questions  Question[]
  userQuizzes UserQuiz[]

  @@map("quizzes")
}

model Question {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  content       String       @db.String
  answers       String[]
  correctAnswer String
  points        Int          @default(1)
  quizId        String?      @db.ObjectId
  examId        String?      @db.ObjectId
  quiz          Quiz?        @relation(fields: [quizId], references: [id])
  exam          Exam?        @relation(fields: [examId], references: [id])

  @@index([quizId])
  @@index([examId])
  @@map("questions")
}

model Video {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  title      String        @db.String
  sequenceId String        @unique @db.ObjectId
  duration   Int
  format     String        @db.String
  link       String
  thumbnail  String?
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])

  @@map("videos")
}

model File {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  fileName   String        @db.String
  sequenceId String        @unique @db.ObjectId
  url        String
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])

  @@map("files")
}

model Exam {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  title        String    @db.String
  courseId     String    @unique @db.ObjectId
  duration     Int
  passingScore Int       @default(70)
  course       Course    @relation(fields: [courseId], references: [id])
  questions    Question[]

  @@map("exams")
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String   @db.String
  userId    String   @db.ObjectId
  quizId    String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
  @@map("notes")
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}
