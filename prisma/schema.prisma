generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Enrollment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  courseId    String   @db.ObjectId
  enrolledAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model UserQuiz {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  quizId     String   @db.ObjectId
  score      Int      @default(0)
  passed     Boolean  @default(false)
  attemptedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
  @@map("user_quizzes")
}

model UserCourse {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  courseId  String   @db.ObjectId
  progress  Float    @default(0)
  startedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@map("user_courses")
}

model UserExam {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  examId     String   @db.ObjectId
  score      Int      @default(0)
  passed     Boolean  @default(false)
  attemptedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId])
  @@index([examId])
  @@map("user_exams")
}

model Certificate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  courseId  String   @db.ObjectId
  issuedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

model Glossary {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  word        String   @db.String
  translation String   @db.String
  explanation String   @db.String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("glossary")
}

model SpeakingEvent {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  title       String              @db.String
  description String              @db.String
  date        DateTime
  createdBy   String              @db.ObjectId
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  creator     User                @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants EventParticipation[]

  @@index([createdBy])
  @@map("speaking_events")
}

model EventParticipation {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  userId    String        @db.ObjectId
  eventId   String        @db.ObjectId
  joinedAt  DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     SpeakingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("event_participations")
}

model User {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  email          String            @unique
  name           String            @db.String
  password       String
  phoneNumber    String?           @db.String 
  profession     String?           @db.String
  yearOfStudy    Int?              @db.Int
  isVerified     Boolean           @default(false)
  role           UserRole          @default(STUDENT)
  balance        Float             @default(0)
  specialty      String?           @db.String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  profilePicture String?
  accounts       Account[]
  sessions       Session[]
  enrollments    Enrollment[]
  userQuizzes    UserQuiz[]
  userSpeechQuizzes UserSpeechQuiz[]
  userCourses    UserCourse[]
  notes          Note[]
  userExams      UserExam[]
  certificates   Certificate[]
  glossary       Glossary[]
  eventParticipations EventParticipation[]
  createdEvents  SpeakingEvent[]   @relation("EventCreator")

  @@index([role])
  @@map("users")
}

model Course {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  title         String           @db.String
  description   String           @db.String
  price         Float
  thumbnail     String?
  published     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  rating        Float            @default(0)
  totalStudents Int              @default(0)
  sequences     CourseSequence[]
  enrollments   Enrollment[]
  userCourses   UserCourse[]
  exam          Exam?
  certificates  Certificate[]

  @@index([published])
  @@index([price])
  @@map("courses")
}

model Quiz {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  title      String         @db.String
  sequenceId String         @unique @db.ObjectId
  duration   Int?
  attempts   Int            @default(1)
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])
  questions  Question[]
  userQuizzes UserQuiz[]

  @@map("quizzes")
}


model Video {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  title      String         @db.String
  sequenceId String         @unique @db.ObjectId
  duration   Int
  format     String         @db.String
  link       String
  thumbnail  String?
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])

  @@map("videos")
}

model File {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  fileName   String         @db.String
  sequenceId String         @unique @db.ObjectId
  url        String
  sequence   CourseSequence @relation(fields: [sequenceId], references: [id])

  @@map("files")
}

model Exam {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  title        String     @db.String
  courseId     String     @unique @db.ObjectId
  duration     Int
  passingScore Int        @default(70)
  course       Course     @relation(fields: [courseId], references: [id])
  questions    Question[]
  userExams    UserExam[]

  @@map("exams")
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String   @db.String
  userId    String   @db.ObjectId
  quizId    String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
  @@map("notes")
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}


model SpeechQuiz {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  title        String         @db.String
  sequenceId   String         @unique @db.ObjectId
  duration     Int?
  attempts     Int            @default(1)
  sequence     CourseSequence @relation(fields: [sequenceId], references: [id])
  questions    Question[]
  userSpeechQuizzes UserSpeechQuiz[]
  @@map("speech_quizzes")
}

model Question {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  content       String       @db.String
  answers       String[]     @default([]) // Optional for quiz/exam, empty for speechQuiz
  correctAnswer String?      // Optional for quiz/exam, null for speechQuiz
  points        Int?         // Optional for quiz/exam, null for speechQuiz
  quizId        String?      @db.ObjectId
  examId        String?      @db.ObjectId
  speechQuizId  String?      @db.ObjectId
  quiz          Quiz?        @relation(fields: [quizId], references: [id])
  exam          Exam?        @relation(fields: [examId], references: [id])
  speechQuiz    SpeechQuiz?  @relation(fields: [speechQuizId], references: [id])
  @@index([quizId])
  @@index([examId])
  @@index([speechQuizId])
  @@map("questions")
  UserSpeechQuiz UserSpeechQuiz[]
}

model UserSpeechQuiz {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  userId       String     @db.ObjectId
  speechQuizId String     @db.ObjectId
  questionId   String     @db.ObjectId // Track specific question
  audioUrl     String?    // Store audio file URL
  score        Int?       // Null until admin scores
  notes        String?    // Admin feedback
  passed       Boolean?   // Null until admin scores
  attemptedAt  DateTime   @default(now())
  scoredAt     DateTime?  // When admin scores
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  speechQuiz   SpeechQuiz @relation(fields: [speechQuizId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, speechQuizId, questionId])
  @@index([userId])
  @@index([speechQuizId])
  @@index([questionId])
  @@map("user_speech_quizzes")
}

model CourseSequence {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  title      String       @db.String
  order      Int
  courseId   String       @db.ObjectId
  course     Course       @relation(fields: [courseId], references: [id])
  quiz       Quiz?
  speechQuiz SpeechQuiz?
  video      Video?
  file       File?
  @@index([courseId])
  @@index([order])
  @@map("course_sequences")
}