# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas or local)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://your_user:your_password@cluster.mongodb.net/engmed?retryWrites=true&w=majority"

# ─── NextAuth.js ───────────────────────────────────────────────────────────────
# Secret used to sign/encrypt JWT tokens — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# The canonical URL of the app (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
